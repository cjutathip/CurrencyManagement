@model CurrencyManagement.Models.ConvertViewModel

@{
    ViewData["Title"] = "Currency Converter";
}

<div class="container mt-4">

    <div class="card shadow">

        <div class="card-header bg-primary text-white">
            <h3>Currency Converter</h3>
        </div>

        <div class="card-body">

            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger">
                    @ViewBag.Error
                </div>
            }

            <form asp-action="Index" method="post">

                <div class="mb-3">

                    <label asp-for="Amount" class="form-label"></label>

                    <input asp-for="Amount" class="form-control" />

                    <span asp-validation-for="Amount" class="text-danger"></span>

                </div>

                <div class="mb-3">

                    <label asp-for="FromCurrency" class="form-label"></label>

                    <select asp-for="FromCurrency" class="form-select">

                        <option value="THB">THB - Thai Baht</option>
                        <option value="USD">USD - US Dollar</option>
                        <option value="EUR">EUR - Euro</option>
                        <option value="JPY">JPY - Japanese Yen</option>
                        <option value="GBP">GBP - British Pound</option>

                    </select>

                </div>

                <div class="mb-3">

                    <label asp-for="ToCurrency" class="form-label"></label>

                    <select asp-for="ToCurrency" class="form-select">

                        <option value="THB">THB - Thai Baht</option>
                        <option value="USD">USD - US Dollar</option>
                        <option value="EUR">EUR - Euro</option>
                        <option value="JPY">JPY - Japanese Yen</option>
                        <option value="GBP">GBP - British Pound</option>

                    </select>

                </div>

                <button type="submit" class="btn btn-primary">
                    Convert
                </button>

                <a asp-action="Index"
                   asp-controller="Currency"
                   class="btn btn-secondary">
                    Back
                </a>

            </form>

            <hr />

            <div class="row">

                <div class="col-md-6">

                    <div class="alert alert-info">

                        <h5>Exchange Rate</h5>

                        <h3>@Model.ExchangeRate</h3>

                    </div>

                </div>

                <div class="col-md-6">

                    <div class="alert alert-success">

                        <h5>Converted Amount</h5>

                        <h3>@Model.Result</h3>

                    </div>

                </div>

            </div>

        </div>

    </div>

</div>

@section Scripts
{
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}